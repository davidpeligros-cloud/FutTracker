{
  "name": "futbol-live-app",
  "slug": "futbol-live-app",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:dev:android": "npx.cmd eas-cli build --platform android --profile development",
    "build:dev:ios": "npx.cmd eas-cli build --platform ios --profile development",
    "build:preview:android": "npx.cmd eas-cli build --platform android --profile preview",
    "build:prod:android": "npx.cmd eas-cli build --platform android --profile production",
    "submit:android": "npx.cmd eas-cli submit --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^54.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-purchases": "^10.2.2",
    "react-native-purchases-ui": "^10.2.2",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "~54.0.10"
  }
}
